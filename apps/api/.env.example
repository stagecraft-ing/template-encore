# =============================================================================
# Encore.ts API — environment variables
# Copy to apps/api/.env:  cp .env.example .env
#
# `encore run` loads .env from this directory into process.env (non-secret
# config below). Values declared via secret() in lib/secrets.ts resolve from
# Encore's secret store: for local dev either set them with
#   encore secret set --type local <NAME>
# or rely on the dev fallbacks (JWT → PEM files from `npm run generate-keys`;
# unset Entra/SAML/gateway secrets simply disable those features).
# In production, bind secrets via infra.config.json ($env) or your secrets
# manager / `encore secret set --type prod <NAME>`.
# =============================================================================

# --- Core ---
NODE_ENV=development
PORT=4000
# Used by infra.config.json for `encore build docker --config` / self-host.
POSTGRES_PASSWORD=change-me

# --- URLs ---
# Public base URL of this API — builds OAuth/SAML callback URLs.
API_BASE_URL=http://localhost:4000
# Allowed SPA origin(s) for post-login redirect (comma-separated; first wins).
FRONTEND_URL=http://localhost:5173

# --- Auth driver selection ---
# Default driver for /api/v1/auth/login + /api/v1/auth/callback. mock | entra-id | saml
AUTH_DRIVER=mock
# Optional explicit callback URL override (else derived from API_BASE_URL).
# AUTH_CALLBACK_URL=

# --- JWT signing keys (SECRETS) ---
# Dev: run `npm run generate-keys` to create apps/api/keys/*.pem (auto-loaded).
# Prod: set these as Encore secrets (PEM strings).
# JWT_PRIVATE_KEY=
# JWT_PUBLIC_KEY=
# JWT_REFRESH_PRIVATE_KEY=
# JWT_REFRESH_PUBLIC_KEY=

# --- CSRF (SECRET) ---
# HMAC key for CSRF token signatures. `npm run generate-keys` prints a suggestion.
# CSRF_SECRET=

# --- Microsoft Entra ID (OIDC) ---
# Tenant is identifier-level config; client id/secret are SECRETS.
# IDPV-001: tenant MUST be a single tenant GUID/domain in production
# (never 'common'/'organizations'/'consumers').
# ENTRA_TENANT_ID=
# ENTRA_CLIENT_ID=           # secret
# ENTRA_CLIENT_SECRET=       # secret
# ENTRA_AUTHORITY=           # optional, else https://login.microsoftonline.com/<tenant>/v2.0
ENTRA_SCOPE=openid profile email
ENTRA_DEFAULT_ROLE=user
# ENTRA_POST_LOGOUT_REDIRECT_URI=

# --- SAML 2.0 ---
# URLs/identifiers are config; keys/certs are SECRETS (base64 or PEM accepted).
# SAML_ENTRY_POINT=          # IdP SSO URL
# SAML_ISSUER=               # SP entity ID
# SAML_CALLBACK_URL=         # else derived: <API_BASE_URL>/api/v1/auth/saml/callback
# SAML_LOGOUT_URL=
# SAML_LOGOUT_CALLBACK_URL=
SAML_IDENTIFIER_FORMAT=urn:oasis:names:tc:SAML:1.1:nameid-format:emailAddress
# SAML_PRIVATE_KEY=          # secret (SP signing/decryption key)
# SAML_CERT_SP=              # secret (SP public cert for metadata)
# SAML_CERT=                 # secret (IdP signing cert)
# Optional attribute-claim overrides (defaults are the standard schemas.xmlsoap URNs):
# SAML_ATTR_ID=
# SAML_ATTR_EMAIL=
# SAML_ATTR_NAME=
# SAML_ATTR_FIRSTNAME=
# SAML_ATTR_LASTNAME=
# SAML_ATTR_ROLES=

# --- BFF gateway (private backend proxy: /api/v1/data/*) ---
# PRIVATE_API_BASE_URL=https://private-backend.internal/api/v1
# GATEWAY_OAUTH_TOKEN_URL=   # else derived from GATEWAY_OAUTH_TENANT_ID
# GATEWAY_OAUTH_TENANT_ID=
# GATEWAY_OAUTH_SCOPE=api://private-app/.default
# GATEWAY_OAUTH_CLIENT_ID=       # secret
# GATEWAY_OAUTH_CLIENT_SECRET=   # secret
# GATEWAY_TIMEOUT_MS=30000

# --- Rate limiting ---
RATE_LIMIT_API_MAX=100
RATE_LIMIT_API_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_AUTH_WINDOW_MS=900000
# REDIS_URL=redis://localhost:6379   # optional — enables Redis-backed limits

# --- Static client serving ---
SERVE_CLIENT=false
WEB_APP=web

# --- Logging ---
# Must be false (or unset) in production — the app fails fast otherwise.
LOG_PII=false
