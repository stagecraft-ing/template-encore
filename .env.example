# =============================================================================
# Environment Configuration - Development
# =============================================================================
# This is a template for local development with mock authentication.
# Copy this file to .env and adjust values as needed.
#
# PLACEHOLDER PATTERN: Values wrapped in {{VARIABLE_NAME}} are placeholders.
# Replace them with your actual values (remove the {{ }} brackets).
#
# For production deployments, use:
# - .env.external.example for SAML 2.0 (your SAML IdP, public-facing)
# - .env.internal.example for MS Entra ID (Azure AD, internal staff-facing)
#
# Validate configuration: npm run validate-env
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000
HOST=localhost
APP_NAME=Enterprise Application Template

# -----------------------------------------------------------------------------
# Session Management
# -----------------------------------------------------------------------------
# For production, generate a secure random string:
# openssl rand -base64 32
SESSION_SECRET=dev-secret-change-in-production-minimum-32-characters
SESSION_STORE=memory
SESSION_MAX_AGE=28800000                 # 8 hours (Protected B); rolling resets on activity
SESSION_COOKIE_SAME_SITE=lax
# SESSION_COOKIE_SECURE will be auto-set based on NODE_ENV

# Redis (Session Store) — uncomment for production or testing with Redis
# SESSION_STORE=redis
# REDIS_URL=redis://localhost:6379
#
# Redis auth mode: accesskey (default, uses REDIS_URL) or entraid (Entra ID token)
# REDIS_AUTH_MODE=accesskey
#
# Entra ID Redis auth (UAT/PROD) — passwordless via @azure/identity:
# REDIS_AUTH_MODE=entraid
# REDIS_HOST=myredis.redis.cache.windows.net
# REDIS_PORT=6380
# REDIS_USERNAME=<managed-identity-object-id>
# Azure credentials are auto-discovered by DefaultAzureCredential:
#   Managed identity (automatic on Azure), or set AZURE_CLIENT_ID +
#   AZURE_TENANT_ID + AZURE_CLIENT_SECRET for service principal

# -----------------------------------------------------------------------------
# Authentication - Mock Driver (Development)
# -----------------------------------------------------------------------------
AUTH_DRIVER=mock

# Auth callback URL - Optional in most cases
# The callback URL is auto-detected in this priority:
# 1. AUTH_CALLBACK_URL (if explicitly set)
# 2. API_URL + /api/v1/auth/callback
# 3. RENDER_EXTERNAL_URL (auto-set by Render.com)
# 4. HOST:PORT derivation (for local development)
#
# Only set this if auto-detection doesn't work for your deployment:
# AUTH_CALLBACK_URL=http://localhost:3000/api/v1/auth/callback
#
# Alternatively, set API_URL for your deployment:
# API_URL=https://your-api.example.com

# For SAML (your SAML IdP), see .env.external.example
# For Entra ID (Azure AD), see .env.internal.example

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
WEB_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173
CORS_CREDENTIALS=true

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Rate limiting - max requests per 15 minutes per IP
RATE_LIMIT_MAX=10000
AUTH_RATE_LIMIT_MAX=100

# Host header validation (REQ-P1-01) — comma-separated allowed hostnames
# Required in production to prevent host header injection
# ALLOWED_HOSTS=your-app.example.com

# Content Security Policy
# HELMET_CSP=false

# -----------------------------------------------------------------------------
# API Gateway (BFF Proxy to Private Backend)
# -----------------------------------------------------------------------------
# Uncomment and configure to proxy requests through the BFF to the private backend.
# All four OAUTH_* vars are required together. If none are set, the gateway returns 503.
#
# PRIVATE_API_BASE_URL: Include the full API path prefix. The gateway appends the
# path after /api/v1/data/ to this URL. Example:
#   Frontend: GET /api/v1/data/info → Backend: GET {PRIVATE_API_BASE_URL}/info
#
# OAUTH_CLIENT_ID / OAUTH_CLIENT_SECRET: Credentials for the PUBLIC app's
# service principal (this app authenticates itself to get a token).
#
# OAUTH_SECRET: Must be the secret VALUE (a long string), NOT the secret ID (a GUID).
# The value is only visible when first created in the Azure Portal.
#
# OAUTH_SCOPE: The PRIVATE app's Application ID URI + /.default
# Find it: Azure Portal → App registrations → private app → Expose an API
#
# PRIVATE_API_BASE_URL=https://your-private-app.azurewebsites.net/api/v1/public
# OAUTH_TENANT_ID=your-azure-tenant-id
# OAUTH_CLIENT_ID=public-app-client-id
# OAUTH_CLIENT_SECRET=public-app-secret-VALUE
# OAUTH_SCOPE=api://private-app-client-id/.default

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=debug
LOG_FORMAT=dev
LOG_PII=false

# -----------------------------------------------------------------------------
# OpenTelemetry (LOG-007)
# Cloud-agnostic telemetry — works with any OTLP-compatible backend
# (Azure Monitor, Datadog, Grafana, Jaeger, etc.)
# -----------------------------------------------------------------------------
OTEL_ENABLED=false
OTEL_SERVICE_NAME=acme-api
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# -----------------------------------------------------------------------------
# Docker Compose (required when using docker compose up)
# These are only needed if you run services via docker-compose.yml.
# -----------------------------------------------------------------------------
# POSTGRES_USER=appuser
# POSTGRES_PASSWORD  — generate with: openssl rand -hex 16
# POSTGRES_DB=app_dev
#
# DB_CONNECTION_STRING must match the postgres service above:
# DB_CONNECTION_STRING=postgresql://appuser:${POSTGRES_PASSWORD}@postgres:5432/app_dev
#   ^^ use "postgres" (service name) as the host when connecting from within Docker
#   ^^ use "localhost" as the host when connecting from outside Docker (e.g. migrations)

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
FEATURE_ANALYTICS=true
FEATURE_HEALTH_CHECK=true
