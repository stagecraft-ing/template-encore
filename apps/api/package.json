{
  "name": "@template/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Encore.ts backend for the Vue + Encore enterprise template (standalone; excluded from the root npm workspaces).",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "encore run --port=4000",
    "typecheck": "encore check",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "generate-keys": "tsx scripts/generate-keys.ts",
    "gen:client": "encore gen client --output=../web/src/lib/encore-client.ts --env=local --lang=typescript",
    "build:docker": "bash scripts/docker-build.sh",
    "migrate": "node scripts/migrate.mjs"
  },
  "dependencies": {
    "@node-saml/node-saml": "^5.0.1",
    "encore.dev": "^1.57.8",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "openid-client": "^6.1.7",
    "pg": "^8.22.0",
    "rate-limiter-flexible": "^11.2.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^26.0.0",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.0.18"
  }
}