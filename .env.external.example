# =============================================================================
# Environment Configuration - EXTERNAL (SAML 2.0)
# =============================================================================
# This configuration is for public-facing enterprise applications using
# SAML 2.0 authentication for external users via your SAML identity provider.
#
# Copy this file to .env and fill in the values from your SAML Identity Provider.
#
# PLACEHOLDER PATTERN: Values wrapped in {{VARIABLE_NAME}} are placeholders.
# Replace them with your actual values (remove the {{ }} brackets).
# Example: {{YOUR_SAML_IDP_SSO_URL}} → https://idp.example.com/saml/sso
#
# See docs/AUTH-SETUP.md for detailed setup instructions.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=production
PORT=3000
HOST=localhost
APP_NAME=Enterprise Application Template

# -----------------------------------------------------------------------------
# Session Management (Redis)
# -----------------------------------------------------------------------------
# Generate a secure random string (32+ characters) for production
# Example: openssl rand -base64 32
SESSION_SECRET={{GENERATE_WITH_OPENSSL_RAND_BASE64_32}}
# Previous session secret for graceful key rotation (optional)
# SESSION_SECRET_PREVIOUS={{OLD_SESSION_SECRET}}
SESSION_STORE=redis
SESSION_MAX_AGE=28800000                 # 8 hours (Protected B); rolling resets on activity

# SameSite=None required for SAML cross-site POST callbacks; requires Secure=true (HTTPS)
SESSION_COOKIE_SAME_SITE=none
SESSION_COOKIE_SECURE=true
# SESSION_COOKIE_NAME=connect.sid

# Redis Authentication Mode
# Option 1: Access Key (simple connection string — good for dev/test)
# REDIS_AUTH_MODE=accesskey
# REDIS_URL=rediss://:{{ACCESS_KEY}}@{{HOSTNAME}}.redis.cache.windows.net:6380
#
# Option 2: Entra ID (recommended for UAT/PROD — passwordless)
REDIS_AUTH_MODE=entraid
REDIS_HOST={{AZURE_REDIS_HOSTNAME}}
REDIS_PORT=6380
REDIS_USERNAME={{MANAGED_IDENTITY_OBJECT_ID}}
# Azure credentials auto-discovered via DefaultAzureCredential
# (Managed Identity on Azure, or AZURE_CLIENT_ID/TENANT_ID/CLIENT_SECRET locally)

# -----------------------------------------------------------------------------
# Authentication - SAML 2.0
# -----------------------------------------------------------------------------
AUTH_DRIVER=saml

# Callback URL - where SAML IdP redirects after authentication (Assertion Consumer Service URL)
# Must match the ACS URL configured in your SAML Identity Provider
# Format: https://your-domain.example.com/api/v1/auth/callback
AUTH_CALLBACK_URL=https://public.app.example.com/api/v1/auth/callback

# SAML IdP Entry Point (SSO URL)
# The URL where users are redirected to authenticate with the Identity Provider
# Example: https://idp.example.com/saml/sso
SAML_ENTRY_POINT={{YOUR_SAML_IDP_SSO_URL}}

# SAML Issuer (Entity ID)
# Unique identifier for your application (Service Provider)
# Format: urn:example:{app-name}:{environment}
SAML_ISSUER=urn:example:app:external

# SAML IdP Certificate (X.509)
# Public certificate from your Identity Provider (base64-encoded, no PEM headers)
SAML_CERT={{YOUR_IDP_CERTIFICATE_BASE64}}

# SAML Service Provider Private Key (base64-encoded, no PEM headers)
# Required for assertion decryption and request signing
# Also used for local HTTPS development (TLS server certificate)
SAML_PRIVATE_KEY={{YOUR_SP_PRIVATE_KEY_BASE64}}

# SAML Service Provider Certificate (base64-encoded, no PEM headers)
# Required for metadata generation and IdP-side encryption
# Also used for local HTTPS development (TLS server certificate)
SAML_CERT_SP={{YOUR_SP_CERTIFICATE_BASE64}}

# SAML Name ID Format
# Default: urn:oasis:names:tc:SAML:1.1:nameid-format:emailAddress
SAML_IDENTIFIER_FORMAT=urn:oasis:names:tc:SAML:2.0:nameid-format:persistent

# SAML Signature / Digest Algorithm (sha1, sha256, sha512)
SAML_SIGNATURE_ALGORITHM=sha256
# SAML_DIGEST_ALGORITHM=sha256

# SAML Assertion / Response Signing Requirements
# Both default to true for secure-by-default posture.
# Only set SAML_WANT_RESPONSE_SIGNED=false if your IdP does not sign the
# response envelope — document the justification when disabling.
SAML_WANT_ASSERTIONS_SIGNED=true
SAML_WANT_RESPONSE_SIGNED=true
# SAML_SIGN_REQUESTS=false
# SAML_FORCE_AUTHN=false

# SAML Attribute Mappings (customize if your IdP uses different claim URIs)
# SAML_ATTR_ID=http://schemas.xmlsoap.org/ws/2005/05/identity/claims/nameidentifier
# SAML_ATTR_EMAIL=http://schemas.xmlsoap.org/ws/2005/05/identity/claims/emailaddress
# SAML_ATTR_NAME=http://schemas.xmlsoap.org/ws/2005/05/identity/claims/name
# SAML_ATTR_FIRSTNAME=http://schemas.xmlsoap.org/ws/2005/05/identity/claims/givenname
# SAML_ATTR_LASTNAME=http://schemas.xmlsoap.org/ws/2005/05/identity/claims/surname
# SAML_ATTR_ROLES=http://schemas.microsoft.com/ws/2008/06/identity/claims/role
# SAML_DEFAULT_ROLE=user

# -----------------------------------------------------------------------------
# SAML Logout (Single Logout)
# -----------------------------------------------------------------------------
# IdP SLO endpoint URL (where users are redirected to terminate the IdP session)
SAML_LOGOUT_URL={{YOUR_SAML_IDP_LOGOUT_URL}}
# SLO callback URL (where the IdP POSTs the LogoutResponse back)
SAML_LOGOUT_CALLBACK_URL=https://public.app.example.com/api/v1/auth/logout/callback

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
WEB_URL=https://public.app.example.com
CORS_ORIGIN=https://public.app.example.com
CORS_CREDENTIALS=true

# -----------------------------------------------------------------------------
# API Gateway (BFF Proxy to Private Backend)
# -----------------------------------------------------------------------------
PRIVATE_API_BASE_URL={{PRIVATE_BACKEND_URL}}
OAUTH_TENANT_ID={{AZURE_TENANT_ID}}
OAUTH_CLIENT_ID={{S2S_CLIENT_ID}}
OAUTH_CLIENT_SECRET={{S2S_CLIENT_SECRET}}
OAUTH_SCOPE={{S2S_OAUTH_SCOPE}}

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Host header validation — must match your production hostname to prevent host header injection
ALLOWED_HOSTS={{YOUR_DOMAIN}}.example.com
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=5
# HELMET_CSP=true

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=combined
LOG_PII=false

# -----------------------------------------------------------------------------
# OpenTelemetry (optional)
# -----------------------------------------------------------------------------
OTEL_ENABLED=false
OTEL_SERVICE_NAME=acme-api
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
FEATURE_ANALYTICS=true
FEATURE_HEALTH_CHECK=true
