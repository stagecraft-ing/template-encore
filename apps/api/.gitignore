# Encore-generated code + local runtime state
/encore.gen
/.encore

# Dependencies + build output
/node_modules
/dist

# Local JWT signing keys (dev) — generated by `npm run generate-keys`
/keys
*.pem

# Generated API client artifacts (regenerated by `encore gen client`)
/openapi.yaml
encore.gen.go
encore.gen.cue

# Built SPA bundle (apps/web builds here). Track only the dev placeholder;
# real builds (assets/, hashed bundles) come from `npm run build:web`.
/web/build/*
!/web/build/index.html
