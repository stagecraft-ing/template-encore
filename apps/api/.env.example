# apps/api environment template. Non-secret config is read via process.env
# (lib/env.ts); secret material is read via Encore secret() (lib/secrets.ts) and
# MUST NOT be committed. Copy to .env for local development.

# === Core ===
PORT=4000
NODE_ENV=development

# Default SSO driver for GET /api/v1/auth/login: mock | entra-id | saml
AUTH_DRIVER=mock

# Public SPA origin used for post-login redirects.
FRONTEND_URL=http://localhost:5173

# PII in logs. MUST be false in production: lib/logger.ts fails fast otherwise (INV-11, CC-006).
LOG_PII=false

# === Persistence ===
# Encore provisions a local Postgres for SQLDatabase("app") during `encore run`.
# DATABASE_URL is only consumed by scripts/migrate.mjs for out-of-Encore provisioning.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app

# Optional Redis backing for rate limiting (lib/rate-limit.ts). In-memory when unset.
# REDIS_URL=redis://localhost:6379

# === JWT keys (dev: written into keys/ by `npm run generate-keys`) ===
# Non-dev: set these as Encore secrets, not files.
# JWT_PRIVATE_KEY / JWT_PUBLIC_KEY / JWT_REFRESH_PRIVATE_KEY / JWT_REFRESH_PUBLIC_KEY

# === Microsoft Entra ID (OIDC) driver ===
# ENTRA_TENANT_ID=
# ENTRA_CLIENT_ID=
# ENTRA_CLIENT_SECRET=
# ENTRA_REDIRECT_URI=http://localhost:4000/api/v1/auth/entra-id/callback
# ENTRA_DEFAULT_ROLE=user

# === SAML 2.0 driver ===
# SAML_ENTRY_POINT=
# SAML_ISSUER=
# SAML_CALLBACK_URL=http://localhost:4000/api/v1/auth/saml/callback
# SAML_IDP_CERT=
# SAML_ATTR_ROLES=

# === BFF gateway (S2S OAuth client-credentials to the private backend) ===
# PRIVATE_API_BASE_URL=
# GATEWAY_OAUTH_TOKEN_URL=
# GATEWAY_OAUTH_CLIENT_ID=
# GATEWAY_OAUTH_CLIENT_SECRET=
# GATEWAY_OAUTH_SCOPE=
# GATEWAY_TIMEOUT_MS=30000
