# =============================================================================
# Environment Configuration - INTERNAL (MS Entra ID)
# =============================================================================
# This configuration is for INTERNAL enterprise applications using Microsoft
# Entra ID (Azure AD) authentication for staff users with Microsoft 365 accounts.
#
# Copy this file to .env and fill in the values from your Azure AD app registration.
#
# PLACEHOLDER PATTERN: Values wrapped in {{VARIABLE_NAME}} are placeholders.
# Replace them with your actual values (remove the {{ }} brackets).
# Example: {{YOUR_AZURE_TENANT_ID}} → abc123-def456-ghi789
#
# See docs/AUTH-SETUP.md for detailed setup instructions.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=production
PORT=3000
HOST=localhost
APP_NAME=Internal Application

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
# Connection string format: postgresql://username:password@host:port/database
# For production, use Azure Database for PostgreSQL or similar managed service
DB_CONNECTION_STRING={{DATABASE_CONNECTION_STRING}}

# Schema name (default: app). Hyphens are auto-converted to underscores.
# DB_SCHEMA=app

# Pool configuration (defaults are fine for most workloads)
# DB_POOL_MAX=10
# DB_POOL_MIN=2
# DB_CONNECTION_TIMEOUT=5000
# DB_IDLE_TIMEOUT=30000
# DB_STATEMENT_TIMEOUT=30000
# DB_ENABLE_METRICS=false

# SSL: auto-enabled in production. Set to false only if connecting through a
# trusted private network (e.g., Azure VNet / Private Endpoint).
# DB_SSL_REJECT_UNAUTHORIZED=true

# -----------------------------------------------------------------------------
# Session Management (PostgreSQL)
# -----------------------------------------------------------------------------
# Generate a secure random string (32+ characters) for production
# Example: openssl rand -base64 32
SESSION_SECRET={{GENERATE_WITH_OPENSSL_RAND_BASE64_32}}
# Previous session secret for graceful key rotation (optional)
# SESSION_SECRET_PREVIOUS={{OLD_SESSION_SECRET}}
SESSION_STORE=postgres
SESSION_MAX_AGE=28800000                 # 8 hours (Protected B); rolling resets on activity

# Entra ID uses Authorization Code flow (redirect-based, same origin)
# so SameSite=lax is sufficient and more secure than SameSite=none
SESSION_COOKIE_SAME_SITE=lax
# SESSION_COOKIE_SECURE will be auto-set to true in production
# SESSION_COOKIE_NAME=__session

# -----------------------------------------------------------------------------
# Authentication - Microsoft Entra ID (Azure AD)
# -----------------------------------------------------------------------------
AUTH_DRIVER=entra-id

# Callback URL - where Entra ID redirects after authentication
# Must match the redirect URI configured in Azure AD app registration
# Format: https://your-domain.example.com/api/v1/auth/callback
AUTH_CALLBACK_URL=https://internal.app.example.com/api/v1/auth/callback

# Azure AD Tenant ID
# Found in Azure Portal > Azure Active Directory > Overview
ENTRA_TENANT_ID={{YOUR_AZURE_TENANT_ID}}

# Azure AD Application (client) ID
# Found in Azure Portal > App registrations > Your app > Overview
ENTRA_CLIENT_ID={{YOUR_AZURE_CLIENT_ID}}

# Azure AD Client Secret
# Created in Azure Portal > App registrations > Your app > Certificates & secrets
# IMPORTANT: Store securely (e.g., Azure Key Vault in production)
ENTRA_CLIENT_SECRET={{YOUR_AZURE_CLIENT_SECRET}}

# Token encryption key for encrypting tokens stored in the session
# Recommended for production — generate with: openssl rand -base64 32
# TOKEN_ENCRYPTION_KEY={{GENERATE_WITH_OPENSSL_RAND_BASE64_32}}

# Optional: Custom authority URL (defaults to Microsoft public cloud)
# ENTRA_AUTHORITY=https://login.microsoftonline.com/{tenant-id}/v2.0

# Optional: OpenID Connect scopes (space-separated)
# Default: "openid profile email"
# Add additional scopes if needed (e.g., "User.Read")
# ENTRA_SCOPE=openid profile email User.Read

# Optional: OAuth response type
# Default: "code" (authorization code flow)
# ENTRA_RESPONSE_TYPE=code

# Optional: OAuth response mode
# Default: "query" (parameters in query string)
# ENTRA_RESPONSE_MODE=query

# Optional: Default role for users with no assigned roles
# ENTRA_DEFAULT_ROLE=employee

# Optional: Logout URL
# Format: https://login.microsoftonline.com/{tenant-id}/oauth2/v2.0/logout
# ENTRA_LOGOUT_URL=https://login.microsoftonline.com/{{YOUR_AZURE_TENANT_ID}}/oauth2/v2.0/logout

# Optional: Post-logout redirect URI
# Where to redirect after logout from Entra ID
# ENTRA_POST_LOGOUT_REDIRECT_URI=https://internal.app.example.com

# -----------------------------------------------------------------------------
# Service-to-Service Authentication (Client Credentials)
# -----------------------------------------------------------------------------
# Enable to expose /api/v1/public/* endpoints for other apps (e.g., the public BFF).
# Validates incoming Bearer tokens issued by Azure AD Client Credentials flow.
# SERVICE_AUTH_ENABLED=true
# SERVICE_AUTH_TENANT_ID={{YOUR_AZURE_TENANT_ID}}     # falls back to ENTRA_TENANT_ID
# SERVICE_AUTH_AUDIENCE=api://{{YOUR_AZURE_CLIENT_ID}} # falls back to api://{ENTRA_CLIENT_ID}
# SERVICE_AUTH_ALLOWED_CLIENT_IDS={{PUBLIC_APP_CLIENT_ID}}

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
# URL where the Vue.js app is hosted
WEB_URL=https://internal.app.example.com

# CORS origin (must match WEB_URL for credentials)
CORS_ORIGIN=https://internal.app.example.com
CORS_CREDENTIALS=true

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Host header validation — must match your production hostname to prevent host header injection
ALLOWED_HOSTS={{YOUR_DOMAIN}}.example.com

# Rate limiting - max requests per 15 minutes per IP
RATE_LIMIT_MAX=1000

# Rate limiting for auth endpoints - stricter limits
AUTH_RATE_LIMIT_MAX=10

# HELMET_CSP=true

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Log level: error, warn, info, debug
LOG_LEVEL=info

# Log format: combined, common, dev, short, tiny
LOG_FORMAT=combined

# Do not log PII in production
LOG_PII=false

# -----------------------------------------------------------------------------
# OpenTelemetry (LOG-007)
# Cloud-agnostic telemetry — works with any OTLP-compatible backend
# (Azure Monitor, Datadog, Grafana, Jaeger, etc.)
# -----------------------------------------------------------------------------
OTEL_ENABLED=false
OTEL_SERVICE_NAME=acme-api
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
FEATURE_ANALYTICS=true
FEATURE_HEALTH_CHECK=true
