# Encore.ts CD (EXAMPLE): build the API Docker image and push to a registry.
#
# This is the CONTAINER half of the dual deploy strategy (spec 057): the
# Encore-supported, robust deploy unit is an OCI image (`encore build docker`).
# The NODE-ZIP half (today's continuity) is deploy-azure-webapp-*.yml, which
# packages the same app as an App Service zip started with `node main.mjs`.
# Pick the path that matches your target; see docs/DEPLOYMENT.md.
#
# Rename to `encore-cd.yml` (strip `.example`) and wire the deploy step to your
# target once chosen (Azure Container Apps, App Service for Containers,
# OpenShift, Encore Cloud, etc.). On activation, SHA-pin every third-party
# `uses:` (spec 021); this `.example` keeps version tags for readability and is
# not linted.
#
# Pipeline:
#   1. Build the public SPA into apps/api/web/build (bundled into the image).
#   2. Install the Encore CLI, npm ci in apps/api.
#   3. Build the base image + `encore build docker --base` and push to GHCR.
#   4. Deploy the pushed image to your runtime (see the commented step below).

name: Encore CD (example)

on:
  workflow_dispatch:
  # push:
  #   branches: [main]

permissions:
  contents: read
  packages: write

jobs:
  build-and-push:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-node@v4
        with:
          node-version: "24"
          cache: npm

      - name: Install dependencies (root workspaces)
        run: npm ci

      - name: Build shared packages + public SPA
        run: |
          npm run build:packages
          npm run build:web        # writes apps/api/web/build

      - name: Install Encore CLI
        uses: ./.github/actions/encore-install

      - name: Install API dependencies
        working-directory: ./apps/api
        run: npm ci

      - name: Log in to GHCR
        uses: docker/login-action@v3
        with:
          registry: ghcr.io
          username: ${{ github.actor }}
          password: ${{ secrets.GITHUB_TOKEN }}

      - name: Build + push Encore image
        uses: ./.github/actions/encore-build
        with:
          image-name: ${{ github.repository }}
          registry: ghcr.io

      # ---------------------------------------------------------------------
      # Deploy the pushed image. Example below: Azure Container Apps. Uncomment,
      # set the resource names / secrets, and SHA-pin the azure/login ref on
      # activation (spec 021). Other targets (App Service for Containers,
      # OpenShift, Encore Cloud) follow the same shape: point the runtime at
      # ghcr.io/${{ github.repository }}:${{ github.sha }}.
      # ---------------------------------------------------------------------
      # - name: Log in to Azure
      #   uses: azure/login@<40-hex-sha>  # v3.0.0 (SHA-pin on activation)
      #   with:
      #     creds: ${{ secrets.AZURE_CREDENTIALS }}
      #
      # - name: Deploy to Azure Container Apps
      #   run: |
      #     az containerapp update \
      #       --name "$AZURE_CONTAINERAPP_NAME" \
      #       --resource-group "$AZURE_CONTAINERAPP_RG" \
      #       --image "ghcr.io/${{ github.repository }}:${{ github.sha }}"
      #   env:
      #     AZURE_CONTAINERAPP_NAME: ${{ vars.AZURE_CONTAINERAPP_NAME }}
      #     AZURE_CONTAINERAPP_RG: ${{ vars.AZURE_CONTAINERAPP_RG }}
